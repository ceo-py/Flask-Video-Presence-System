[Unit]
Description=Gunicorn instance for api-camera
After=network.target

[Service]
User=ceo
Group=www-data
WorkingDirectory=/PATH TO

# Your original start command
ExecStart=/bin/bash -c 'source /PATH TO/venv/bin/activate && exec gunicorn --workers 1 --bind 127.0.0.1:8002 api:app'

Restart=always

[Install]
WantedBy=multi-user.target